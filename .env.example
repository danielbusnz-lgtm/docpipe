# AWS
AWS_REGION=us-east-1

# S3
DOCPIPE_S3_BUCKET=docpipe-documents
DOCPIPE_S3_ENDPOINT=http://localhost:4566  # LocalStack

# DynamoDB
DOCPIPE_DYNAMO_TABLE=docpipe-metadata
DOCPIPE_DYNAMO_ENDPOINT=http://localhost:4566  # LocalStack

# PostgreSQL
DOCPIPE_PG_URL=postgresql://docpipe:docpipe@localhost:5432/docpipe

# Bedrock
DOCPIPE_BEDROCK_MODEL=anthropic.claude-sonnet-4-20250514

# Logging
LOG_LEVEL=INFO
