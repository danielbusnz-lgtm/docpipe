# AWS
AWS_REGION=us-east-1

# S3
INKVAULT_S3_BUCKET=inkvault-documents
INKVAULT_S3_ENDPOINT=http://localhost:4566  # LocalStack

# DynamoDB
INKVAULT_DYNAMO_TABLE=inkvault-metadata
INKVAULT_DYNAMO_ENDPOINT=http://localhost:4566  # LocalStack

# PostgreSQL
INKVAULT_PG_URL=postgresql://inkvault:inkvault@localhost:5432/inkvault

# Bedrock
INKVAULT_BEDROCK_MODEL=anthropic.claude-sonnet-4-20250514

# Logging
LOG_LEVEL=INFO
